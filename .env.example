DNSE_API_KEY=
DNSE_API_SECRET=
DNSE_ACCOUNT_NO=
DNSE_STOCK_ACCOUNT_NO=
DNSE_DERIVATIVE_ACCOUNT_NO=
DNSE_CUSTODY_CODE=
DNSE_OTP_TYPE=email_otp
DNSE_BASE_URL=https://openapi.dnse.com.vn
DNSE_API_VERSION=2026-05-07
DNSE_CKCS_WATCHLIST=FPT,SSI,VCB,CTG,BID,MBB
DNSE_CKPS_WATCHLIST=VN30F1M
PAPER_TRADING=True
AUTO_TRADE_ENABLED=False

# --- Market-data WebSocket streaming (giảm tải REST để add nhiều mã không bị BAN) ---
# Bật true để stream giá qua WebSocket thay vì poll REST. Mặc định false (dùng REST + cache).
DNSE_WS_ENABLED=false
DNSE_WS_URL=wss://ws-openapi.dnse.com.vn
DNSE_WS_ENCODING=json
DNSE_WS_BOARD_ID=G1

# --- TTL cache REST (giây): tăng = gọi API ít hơn (an toàn rate-limit), giảm = cập nhật nhanh hơn ---
DNSE_TICK_CACHE_TTL_SECONDS=2.0
DNSE_OHLC_CACHE_TTL_SECONDS=30.0
DNSE_ACCOUNT_CACHE_TTL_SECONDS=5.0
DNSE_POSITIONS_CACHE_TTL_SECONDS=2.0
